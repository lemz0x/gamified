# Cache headers for Cloudflare Pages
#
# SPA routes served via _redirects rewrite to index.html. Cloudflare
# evaluates _headers on the original request path, so /* catches all
# routes (/play, /underlay, /overlay, /producer, /chat, /editorchat).
# Hashed assets in /assets/* never change once published, so let CDNs
# hold them forever.

/*
  Cache-Control: no-cache

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/sfx/*
  Cache-Control: public, max-age=604800
